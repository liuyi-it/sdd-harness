{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdd-harness.dev/schemas/review-report.schema.json",
  "title": "sdd-harness review report v2",
  "type": "object",
  "required": [
    "schemaVersion",
    "changeId",
    "fixedPoint",
    "result",
    "generatedAt",
    "severityCounts",
    "issues",
    "message",
    "standards",
    "spec",
    "summary"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0.0" },
    "changeId": { "type": "string", "minLength": 1 },
    "fixedPoint": { "type": "string", "minLength": 1 },
    "result": { "enum": ["PASS", "BLOCK"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "severityCounts": {
      "type": "object",
      "required": ["MAJOR", "MINOR", "INFO"],
      "properties": {
        "MAJOR": { "type": "integer", "minimum": 0 },
        "MINOR": { "type": "integer", "minimum": 0 },
        "INFO": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "categoryCounts": { "type": "object" },
    "issues": {
      "type": "array",
      "items": { "$ref": "review-issue.schema.json" }
    },
    "message": { "type": "string", "minLength": 1 },
    "standards": { "$ref": "#/$defs/reviewAxis" },
    "spec": { "$ref": "#/$defs/reviewAxis" },
    "summary": {
      "type": "object",
      "required": ["standardsFindingCount", "specFindingCount"],
      "properties": {
        "standardsFindingCount": { "type": "integer", "minimum": 0 },
        "specFindingCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "minimality": {
      "type": "object",
      "required": ["metrics", "dependencyDelta", "deliberateDebts"],
      "properties": {
        "metrics": {
          "type": "object",
          "required": [
            "filesAdded",
            "filesModified",
            "filesDeleted",
            "linesAdded",
            "linesDeleted",
            "netLines",
            "dependenciesAdded",
            "dependenciesRemoved",
            "deliberateDebtCount"
          ],
          "properties": {
            "filesAdded": { "type": "integer", "minimum": 0 },
            "filesModified": { "type": "integer", "minimum": 0 },
            "filesDeleted": { "type": "integer", "minimum": 0 },
            "linesAdded": { "type": ["integer", "null"], "minimum": 0 },
            "linesDeleted": { "type": ["integer", "null"], "minimum": 0 },
            "netLines": { "type": ["integer", "null"] },
            "dependenciesAdded": { "type": "integer", "minimum": 0 },
            "dependenciesRemoved": { "type": "integer", "minimum": 0 },
            "deliberateDebtCount": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "dependencyDelta": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "deliberateDebts": {
          "type": "array",
          "items": { "$ref": "#/$defs/deliberateDebt" }
        },
        "estimatedRemovableLines": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "reviewAxis": {
      "type": "object",
      "required": ["status", "findings"],
      "properties": {
        "status": { "enum": ["PASSED", "FAILED", "SKIPPED"] },
        "findings": {
          "type": "array",
          "items": { "$ref": "review-issue.schema.json" }
        }
      },
      "additionalProperties": false
    },
    "dependencyDelta": {
      "type": "object",
      "required": ["manifest", "section", "name", "before", "after", "change"],
      "properties": {
        "manifest": { "type": "string", "minLength": 1 },
        "section": {
          "enum": [
            "dependencies",
            "devDependencies",
            "peerDependencies",
            "optionalDependencies"
          ]
        },
        "name": { "type": "string", "minLength": 1 },
        "before": { "type": ["string", "null"] },
        "after": { "type": ["string", "null"] },
        "change": { "enum": ["ADDED", "REMOVED", "UPDATED"] }
      },
      "additionalProperties": false
    },
    "deliberateDebt": {
      "type": "object",
      "required": ["file", "line", "ceiling", "trigger", "upgrade"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "ceiling": { "type": "string", "minLength": 1 },
        "trigger": { "type": "string", "minLength": 1 },
        "upgrade": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
