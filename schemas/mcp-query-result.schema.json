{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdd-harness.dev/schemas/mcp-query-result.schema.json",
  "title": "sdd-harness MCP query result",
  "type": "object",
  "required": [
    "schemaVersion",
    "intent",
    "provider",
    "degraded",
    "confidence",
    "generatedAt",
    "payload"
  ],
  "properties": {
    "schemaVersion": { "const": "1.2.0" },
    "intent": {
      "enum": [
        "impact",
        "related-files",
        "symbols",
        "callers",
        "callees",
        "routes",
        "tests",
        "architecture"
      ]
    },
    "provider": {
      "enum": ["codebase-memory-mcp", "fallback-file-scan"]
    },
    "degraded": { "type": "boolean" },
    "reason": { "type": "string", "minLength": 1 },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
